# Used only by legacy/cf-dns-add.sh for manual local runs.
# The GitHub Action reads these from Action inputs, not .env.
# Copy to .env and fill in real values. .env is gitignored.

# Cloudflare API token with Zone > DNS > Edit scope on the target zone.
# Get from: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=

# Cloudflare Zone ID (32 lowercase hex chars). Found in the zone's overview sidebar.
CF_ZONE_ID=

# Apex domain (used by the legacy script to build the FQDN).
CF_DOMAIN=mdpstudio.com.au
