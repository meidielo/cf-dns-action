{
  "name": "cf-dns-action",
  "version": "1.0.0",
  "private": false,
  "description": "GitHub Action that registers custom domains in Netlify and creates/updates matching Cloudflare CNAME records. Idempotent, scoped-token friendly.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "github-action",
    "cloudflare",
    "netlify",
    "dns",
    "cname",
    "custom-domain",
    "idempotent"
  ],
  "author": "Meidie",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
